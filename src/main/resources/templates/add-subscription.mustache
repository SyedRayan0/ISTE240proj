<!DOCTYPE html>
<html>
<body>
<h2>Add New Subscription</h2>
<form action="/subscriptions/add" method="post">
    <label>Subscription ID:</label>
    <input type="text" name="subscriptionId" required><br><br>
    <label>Email:</label>
    <input type="email" name="subscriberEmail" required><br><br>
    <label>Event Title:</label>
    <input type="text" name="eventTitle" required><br><br>
    <button type="submit">Submit</button>
</form>
<br>
<a href="/">Return to Home</a>
</body>
</html>